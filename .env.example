# === Anthropic API (AI 분석용) ===
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-api03-여기에-발급받은-키-입력

# === 한국투자증권 Open API ===
# https://apiportal.koreainvestment.com 에서 발급
KIS_APP_KEY=여기에-앱키-입력
KIS_APP_SECRET=여기에-앱시크릿-입력
KIS_ACCOUNT_NO=계좌번호-예시-12345678-01
KIS_VIRTUAL=false

# === 네이버 뉴스 검색 API (선택사항, 없으면 RSS로 동작) ===
# https://developers.naver.com 에서 발급
NAVER_CLIENT_ID=여기에-네이버-클라이언트-ID
NAVER_CLIENT_SECRET=여기에-네이버-클라이언트-시크릿

# === 텔레그램 봇 (선택사항) ===
# https://t.me/BotFather 에서 발급
TELEGRAM_BOT_TOKEN=여기에-텔레그램-봇-토큰
TELEGRAM_CHAT_ID=여기에-채팅-ID
